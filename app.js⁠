// Функция для отрисовки карточек на экране
function displayProjects(items) {
    const container = document.getElementById('projects-container');
    container.innerHTML = "";

    items.forEach(proj => {
        const card = document.createElement('div');
        card.classList.add('project-card');
        
        card.innerHTML = `
            <div class="project-img">${proj.emoji}</div>
            <div class="project-info">
                <h3>${proj.title}</h3>
                <p>${proj.description}</p>
                <a href="${proj.link}" target="_blank" class="project-btn">Посмотреть проект</a>
            </div>
        `;
        container.appendChild(card);
    });
}

// Функция фильтрации (Все / Игры / Боты)
function filterProjects(category) {
    // Меняем активный класс у кнопок
    const buttons = document.querySelectorAll('.cat-btn');
    buttons.forEach(btn => btn.classList.remove('active'));
    event.target.classList.add('active');

    if (category === 'all') {
        displayProjects(projects);
    } else {
        const filtered = projects.filter(p => p.category === category);
        displayProjects(filtered);
    }
}

// Первая инициализация — показываем все проекты
displayProjects(projects);
